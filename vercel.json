{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/", "dest": "/admin/index.html" },
    { "src": "/admin", "dest": "/admin/index.html" },
    { "src": "/admin/(.*)", "dest": "/admin/$1" },
    { "src": "/pwa", "dest": "/pwa/index.html" },
    { "src": "/pwa/(.*)", "dest": "/pwa/$1" }
  ]
}
